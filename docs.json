{
  "$schema": "https://mintlify.com/docs.json",
  "theme": "almond",
  "name": "BunnyOS",
  "description": "Guides and references for discovering, deploying, and managing autonomous DeFi agents on BunnyOS.",
  "colors": {
    "primary": "#2962FF",
    "light": "#5B82FF",
    "dark": "#1E4FD6"
  },
  "favicon": "/favicon.png",
  "icons": {
    "library": "lucide"
  },
  "styling": {
    "eyebrows": "breadcrumbs"
  },
  "contextual": {
    "options": ["copy", "view", "assistant", "mcp", "add-mcp"]
  },
  "navigation": {
    "global": {
      "anchors": [
        {
          "anchor": "Home",
          "icon": "house",
          "href": "/"
        },
        {
          "anchor": "GitHub",
          "icon": "github",
          "href": "https://github.com/bunnyos/base-agent"
        }
      ]
    },
    "tabs": [
      {
        "tab": "User Guide",
        "icon": "book-open",
        "groups": [
          {
            "group": "Getting Started",
            "icon": "rocket",
            "expanded": true,
            "pages": [
              "user/getting-started/introduction",
              "user/getting-started/wallet-connection",
              "user/getting-started/chat-intro",
              "user/getting-started/data-and-keys"
            ]
          },
          {
            "group": "Portfolio",
            "icon": "wallet",
            "pages": [
              "user/portfolio/overview"
            ]
          },
          {
            "group": "Token Research",
            "icon": "search",
            "pages": [
              "user/tokens/discovery",
              "user/tokens/research"
            ]
          },
          {
            "group": "bunnyDEX",
            "icon": "key-round",
            "pages": [
              "user/bunnyex/trading",
              "user/bunnyex/profiles",
              "user/bunnyex/pnl"
            ]
          },
          {
            "group": "Actions",
            "icon": "zap",
            "pages": [
              "user/actions/inbox",
              "user/actions/builder",
              "user/actions/management"
            ]
          },
          {
            "group": "bunnyCompute",
            "icon": "server",
            "pages": [
              "user/bunnyds/overview",
              "user/bunnyds/spending"
            ]
          },
          {
            "group": "Configuration",
            "icon": "settings",
            "pages": [
              "user/configure/api-keys",
              "user/configure/llm",
              "user/configure/services",
              "user/configure/memory",
              "user/configure/bunnyos-account"
            ]
          }
        ]
      },
      {
        "tab": "Developer",
        "icon": "code",
        "groups": [
          {
            "group": "Introduction",
            "icon": "book-open",
            "expanded": true,
            "pages": [
              "developer/overview"
            ]
          },
          {
            "group": "bunnyDEX API",
            "icon": "key-round",
            "expanded": true,
            "pages": [
              "developer/exchange/overview",
              "developer/exchange/authentication",
              "developer/exchange/market-data",
              "developer/exchange/profile",
              "developer/exchange/recommendations",
              "developer/exchange/threads"
            ]
          },
          {
            "group": "Self-Hosting",
            "icon": "server",
            "expanded": true,
            "pages": [
              "developer/self-hosting/overview",
              "developer/self-hosting/quickstart",
              "developer/self-hosting/configuration",
              "developer/self-hosting/security"
            ]
          }
        ]
      },
      {
        "tab": "Whitepaper",
        "icon": "scroll-text",
        "href": "https://bunnyos.ai/litepaper"
      }
    ]
  },
  "logo": {
    "light": "/logo/light.png",
    "dark": "/logo/dark.png"
  },
  "navbar": {
    "links": [],
    "primary": {
      "type": "button",
      "label": "Launch App",
      "href": "https://bunnyos.ai"
    }
  },
  "footer": {
    "socials": {
      "x": "https://x.com/officialbunnyos"
    }
  }
}
